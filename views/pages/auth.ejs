<!DOCTYPE html>
<html lang="en">

<head>
    <title>Dashboard</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
        /* --- Base Reset & Typography --- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }

        body {
            background: #f4F6F9;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            color: #333;
            padding: 40px 20px;
        }

        .container {
            width: 100%;
            max-width: 1000px;
            margin: 0 auto;
        }

        /* --- Login Card Panel Styling --- */
        #login-container {
            width: 100%;
            display: flex;
            justify-content: center;
            margin-top: 60px;
        }

        #login-container .center {
            background: #ffffff;
            border-radius: 10px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
            width: 100%;
            max-width: 400px;
            padding: 30px;
            transition: transform 0.3s ease;
        }

        #login-container h1 {
            font-size: 24px;
            font-weight: 600;
            color: #2c3e50;
            text-align: center;
            margin-bottom: 25px;
        }

        #login-container .txt_field {
            position: relative;
            margin-bottom: 20px;
        }

        #login-container .txt_field input {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e2e8f0;
            border-radius: 6px;
            outline: none;
            font-size: 15px;
            transition: border-color 0.2s ease;
            background: #f8fafc;
        }

        #login-container .txt_field input:focus {
            border-color: #007bff;
            background: #fff;
        }

        #login-container #authButton {
            width: 100%;
            background: #007bff;
            color: #fff;
            border: none;
            border-radius: 6px;
            padding: 14px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s ease, opacity 0.2s ease;
            box-shadow: 0 4px 12px rgba(0, 123, 255, 0.2);
        }

        #login-container #authButton:hover {
            background: #0056b3;
        }

        #login-container #authButton:disabled {
            background: #6c757d;
            cursor: not-allowed;
            box-shadow: none;
        }

        /* --- Secured Dashboard Workspace Layout --- */
        #dashboard-container {
            background: #ffffff;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
            margin-top: 40px;
        }

        /* Tab Headers navigation block */
        .tab-navigation {
            display: flex;
            border-bottom: 2px solid #edf2f7;
            margin-bottom: 25px;
            gap: 10px;
        }

        .tab-button {
            background: none;
            border: none;
            padding: 12px 24px;
            font-size: 16px;
            font-weight: 500;
            color: #718096;
            cursor: pointer;
            outline: none;
            border-bottom: 3px solid transparent;
            transition: all 0.2s ease;
        }

        .tab-button:hover {
            color: #2d3748;
            background: #f8fafc;
            border-radius: 6px 6px 0 0;
        }

        .tab-button.active {
            border-bottom-color: #007bff;
            color: #007bff;
            font-weight: 600;
        }

        /* Content Container Boxes */
        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        .tab-content h2 {
            font-size: 22px;
            color: #1a202c;
            margin-bottom: 20px;
            font-weight: 600;
        }

        .tab-header-flex {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        /* --- Tab A: Inquiry Log Cards --- */
        .inquiry-card {
            border: 1px solid #e2e8f0;
            padding: 20px;
            margin-bottom: 15px;
            border-radius: 8px;
            background: #ffffff;
            text-align: left;
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        }

        .inquiry-card:hover {
            box-shadow: 0 6px 16px rgba(0, 0, 0, 0.04);
            border-color: #cbd5e0;
        }

        .inquiry-card-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
        }

        .inquiry-card-id {
            font-size: 12px;
            color: #718096;
        }

        .inquiry-card-body-text {
            margin: 12px 0 0 0;
            background: #f8fafc;
            padding: 12px;
            border-left: 3px solid #007bff;
            font-size: 14px;
            border-radius: 0 4px 4px 0;
        }

        .sort-btn {
            background: #fff;
            border: 1px solid #cbd5e0;
            padding: 8px 14px;
            font-size: 14px;
            font-weight: 500;
            border-radius: 6px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s ease;
        }

        .sort-btn:hover {
            background: #f8fafc;
            border-color: #a0aec0;
        }

        /* --- Tab B: Admin Career Component Modules --- */
        .job-form {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 30px;
        }

        .job-form h3 {
            margin-bottom: 15px;
            font-size: 16px;
            color: #4a5568;
        }

        .job-form input[type="text"],
        .job-form textarea,
        .job-form select {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #cbd5e0;
            border-radius: 6px;
            background: #fff;
            font-size: 14px;
            outline: none;
            transition: border-color 0.2s;
        }

        .job-form input:focus,
        .job-form textarea:focus,
        .job-form select:focus {
            border-color: #007bff;
        }

        .job-form button {
            background: #28a745;
            color: white;
            border: none;
            padding: 10px 20px;
            font-size: 14px;
            font-weight: 500;
            border-radius: 6px;
            cursor: pointer;
            transition: background 0.2s;
        }

        .job-form button:hover {
            background: #218838;
        }

        #cancel-edit-btn {
            background: #6c757d;
            margin-left: 10px;
        }

        #cancel-edit-btn:hover {
            background: #5a6268;
        }

        /* Career Row Postings */
        .job-item {
            background: #fff;
            border: 1px solid #edf2f7;
            border-radius: 8px;
            padding: 15px 20px;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: background 0.2s, border-color 0.2s;
        }

        .job-item:hover {
            background: #fdfdfd;
            border-color: #e2e8f0;
        }

        .job-item button {
            border: 1px solid #cbd5e0;
            background: #fff;
            padding: 6px 12px;
            font-size: 13px;
            border-radius: 4px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .job-item button:hover {
            background: #edf2f7;
            color: #000;
        }

        .job-item .delete-btn {
            background: #fff;
            color: #dc3545;
            border-color: #f5c6cb;
            margin-left: 5px;
        }

        .job-item .delete-btn:hover {
            background: #dc3545;
            color: #fff;
            border-color: #dc3545;
        }

        /* Status Badges */
        .status-open {
            background: #e6f4ea;
            color: #137333;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: bold;
            text-transform: uppercase;
        }

        .status-filled {
            background: #fce8e6;
            color: #c5221f;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: bold;
            text-transform: uppercase;
        }
    </style>
</head>

<body>
    <div class="container">
        <!-- 1. LOGIN INTERFACE CONTAINER (Visible by default) -->
        <div id="login-container">
            <div class="center">
                <h1>Dashboard Login</h1>
                <form action="" method="POST" onsubmit="return false;">
                    <div class="txt_field">
                        <input id="uname" type="text" placeholder="Username" required>
                    </div>
                    <div class="txt_field">
                        <input id="pword" type="password" placeholder="Password" required>
                    </div>
                    <input id="authButton" type="button" value="Login">
                </form>
            </div>
        </div>

        <!-- 2. SECURE DASHBOARD CONTAINER (Hidden until authenticated) -->
        <div id="dashboard-container" style="display: none;">
            <!-- Tab Navigation Header -->
            <div class="tab-navigation">
                <button id="tab-inquiries-btn" class="tab-button active" onclick="switchTab('inquiries')">Customer
                    Inquiries</button>
                <button id="tab-admin-btn" class="tab-button" onclick="switchTab('admin')">Admin (Careers)</button>
            </div>

            <!-- TAB A: INQUIRIES LIST -->
            <div id="inquiries" class="tab-content active">
                <div class="tab-header-flex">
                    <h2>Customer Requests &amp; Quote Inquiries</h2>
                    <button id="sort-inquiries-btn" class="sort-btn" onclick="toggleInquiriesSort()">
                        <span>↓ Newest First</span>
                    </button>
                </div>
                <div id="inquiries-list">
                    <p>Loading real-time submissions...</p>
                </div>
            </div>

            <!-- TAB B: ADMIN (Careers Management) -->
            <div id="admin" class="tab-content">
                <h2>Careers Management</h2>

                <!-- Create / Edit Form -->
                <div class="job-form">
                    <h3 id="form-title">Create New Job Post</h3>
                    <input type="hidden" id="job-id">
                    <div class="txt_field">
                        <input type="text" id="job-title" placeholder="Job Title" required>
                    </div>
                    <div class="txt_field">
                        <textarea id="job-desc" placeholder="Job Description" required></textarea>
                    </div>
                    <div style="margin-bottom: 15px;">
                        <label for="job-status" style="font-size: 14px; color: #4a5568;">Status: </label>
                        <select id="job-status" style="width: auto; display: inline-block; margin-left: 5px;">
                            <option value="open">Open</option>
                            <option value="filled">Filled</option>
                        </select>
                    </div>
                    <button id="save-job-btn" onclick="saveJob()">Post Job</button>
                    <button id="cancel-edit-btn" onclick="resetJobForm()" style="display:none;">Cancel</button>
                    <button id="delete-all-btn" onclick="deleteAllJobs()">Delete All Jobs</button>

                </div>

                <!-- Existing Jobs List -->
                <h3 style="font-size: 18px; color: #2c3e50; margin-bottom: 15px;">Current Job Postings</h3>
                <div id="admin-jobs-list">
                    <p>Loading job updates...</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        // --- Global App State Management ---
        let allInquiries = [];       // Holds raw array of inquiries
        let inquiriesSortNewest = true; // State tracker: true = Newest first, false = Oldest first
        let allJobs = [];            // Holds job postings array

        // --- Tab Switching Logic ---
        function switchTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.tab-button').forEach(el => el.classList.remove('active'));

            document.getElementById(tabId).classList.add('active');

            if (tabId === 'inquiries') {
                document.getElementById('tab-inquiries-btn').classList.add('active');
                fetchInquiries();
            } else if (tabId === 'admin') {
                document.getElementById('tab-admin-btn').classList.add('active');
                fetchAdminJobs();
            }
        }

        // --- Authentication Event Listener ---
        document.getElementById('authButton').addEventListener('click', async () => {
            const authButton = document.getElementById('authButton');
            const uname = document.getElementById('uname').value;
            const pword = document.getElementById('pword').value;

            if (!uname || !pword) {
                window.alert("Fields cannot be empty");
                return;
            }
            authButton.disabled = true;
            authButton.value = "Authenticating...";

            try {
                const payload = { 'uname': uname, 'pword': pword };
                const response = await fetch('/firebase/auth', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const user = await response.json();

                if (user && user.user) {
                    authButton.value = "Success!";

                    // Reveal dashboard and clean away login fields securely
                    document.getElementById('login-container').style.display = 'none';
                    document.getElementById('dashboard-container').style.display = 'block';

                    // Populate initial tab inquiries right away
                    fetchInquiries();
                } else {
                    throw new Error("Invalid admin verification response structure");
                }
            } catch (error) {
                console.error('Error calling /auth:', error);
                window.alert("Authentication failed. Invalid details provided.");

                document.getElementById('uname').value = "";
                document.getElementById('pword').value = "";
                authButton.disabled = false;
                authButton.value = "Login";
            }
        });

        // --- Tab A: Inquiries Data Management System ---
        async function fetchInquiries() {
            const container = document.getElementById('inquiries-list');
            try {
                const response = await fetch('/firebase/requests', { method: 'POST' });
                const data = await response.json();

                if (!data || Object.keys(data).length === 0) {
                    container.innerHTML = '<p>No customer quote inquiries found inside database logs.</p>';
                    allInquiries = [];
                    return;
                }

                // Map database keys (timestamps) into an object array for processing
                allInquiries = Object.keys(data).map(key => {
                    return {
                        id: key,
                        ...data[key]
                    };
                });

                // Render with current default sorting configuration (Newest First)
                renderInquiries();

            } catch (err) {
                console.error("Failed fetching submission info logs", err);
                container.innerHTML = '<p style="color: red;">Error displaying data entries. Session expired.</p>';
            }
        }

        function renderInquiries() {
            const container = document.getElementById('inquiries-list');
            if (allInquiries.length === 0) {
                container.innerHTML = '<p>No customer quote inquiries found inside database logs.</p>';
                return;
            }

            // Copy and explicitly sort by timestamp metrics
            let processedList = [...allInquiries];
            processedList.sort((a, b) => {

                const dateA = a.date ? new Date(a.date) : a.id;
                const dateB = b.date ? new Date(b.date) : b.id;

                if (inquiriesSortNewest) {
                    return dateB > dateA ? 1 : -1;
                } else {
                    return dateA > dateB ? 1 : -1;
                }
            });

            // Rebuild container interface
            container.innerHTML = processedList.map(item => `
        <div class="inquiry-card">
            <div class="inquiry-card-header">
                <strong>Client Name: ${item.name || 'Anonymous'}</strong>
                <span class="inquiry-card-id">${item.date || item.id}</span>
            </div>
            <p style="margin: 2px 0;"><strong>Phone:</strong> ${item.phone || 'N/A'}</p>
            <p style="margin: 2px 0;"><strong>Requested Service:</strong> ${item.service || 'General'}</p>
            <p class="inquiry-card-body-text">"${item.message || ''}"</p>
        </div>
    `).join('');
        }

        function toggleInquiriesSort() {
            inquiriesSortNewest = !inquiriesSortNewest;

            // Update button visual label state
            const btnSpan = document.querySelector('#sort-inquiries-btn span');
            if (inquiriesSortNewest) {
                btnSpan.innerText = "↓ Newest First";
            } else {
                btnSpan.innerText = "↑ Oldest First";
            }

            // Re-render items using updated layout priority configurations
            renderInquiries();
        }

        // --- Tab B: Careers Management System Logic ---
        async function fetchAdminJobs() {
            try {
                const response = await fetch('/api/careers/list');
                console.log(response)
                allJobs = (await response.json())?.jobs;;
                renderAdminJobs();
            } catch (err) {
                console.error("Failed fetching jobs", err);
            }
        }

        function renderAdminJobs() {
            const container = document.getElementById('admin-jobs-list');
            if (allJobs.length === 0) {
                container.innerHTML = '<p>No job postings found.</p>';
                return;
            }
            container.innerHTML = allJobs.map(job => `
                <div class="job-item">
                    <div style="text-align: left; padding-right: 15px;">
                        <strong style="font-size: 16px; color: #2d3748;">${job.title}</strong>
                        <span class="status-${job.status}" style="margin-left: 8px;">${job.status.toUpperCase()}</span>
                        <p style="margin: 8px 0 0 0; font-size:14px; color:#4a5568; line-height: 1.5;">${job.description}</p>
                    </div>
                    <div style="display: flex; flex-shrink: 0;">
                        <button onclick="editJobSetup('${job.id}')">Edit</button>
                        <button class="delete-btn" onclick="deleteJob('${job.id}')">Delete</button>
                    </div>
                </div>
            `).join('');
        }

        async function saveJob() {
            const id = document.getElementById('job-id').value;
            const title = document.getElementById('job-title').value;
            const description = document.getElementById('job-desc').value;
            const status = document.getElementById('job-status').value;

            if (!title || !description) return alert("Please fill out all fields");
            const url = id ? `/api/careers/update/${id}` : '/api/careers/create';

            try {
                const res = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title, description, status })
                });
                if (res.ok) {
                    resetJobForm();
                    fetchAdminJobs();
                }
            } catch (err) {
                console.error("Error saving job listing", err);
            }
        }

        function editJobSetup(id) {
            const job = allJobs.find(j => j.id === id);
            if (!job) return;

            document.getElementById('job-id').value = job.id;
            document.getElementById('job-title').value = job.title;
            document.getElementById('job-desc').value = job.description;
            document.getElementById('job-status').value = job.status;

            document.getElementById('form-title').innerText = "Edit Job Post";
            document.getElementById('save-job-btn').innerText = "Update Job";
            document.getElementById('cancel-edit-btn').style.display = "inline-block";
        }

        function resetJobForm() {
            document.getElementById('job-id').value = "";
            document.getElementById('job-title').value = "";
            document.getElementById('job-desc').value = "";
            document.getElementById('job-status').value = "open";

            document.getElementById('form-title').innerText = "Create New Job Post";
            document.getElementById('save-job-btn').innerText = "Post Job";
            document.getElementById('cancel-edit-btn').style.display = "none";
        }

        async function deleteAllJobs(id) {
            if (!confirm("Are you sure you want to drop this job posting?")) return;
            try {
                const res = await fetch(`/api/careers/deleteAll`, { method: 'POST' });
                if (res.ok) fetchAdminJobs();
            } catch (err) {
                console.error("Error deleting job", err);
            }
        }
        async function deleteJob(id) {
            if (!confirm("Are you sure you want to drop this job posting?")) return;
            try {
                const res = await fetch(`/api/careers/delete/${id}`, { method: 'POST' });
                if (res.ok) fetchAdminJobs();
            } catch (err) {
                console.error("Error deleting job", err);
            }
        }
    </script>
</body>

</html>